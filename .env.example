# ─────────────────────────────────────────────────────────────
# Backend (app.py) — variables d'environnement
# Copie ce fichier en .env pour le dev local, ou définis ces
# variables sur ton hébergeur backend (Render / Hugging Face Space).
# ─────────────────────────────────────────────────────────────

# Débogage Flask : TOUJOURS False en production (True = faille de sécurité)
FLASK_DEBUG=False

# Port d'écoute. En local : 5000. (Render fournit $PORT ; HF Spaces = 7860.)
PORT=5000

# CORS : origines autorisées à appeler l'API (le front), séparées par des virgules.
# En production, mets l'URL de ton front Netlify :
CORS_ORIGINS=https://textymyel.netlify.app

# Taille maximale des fichiers uploadés, en OCTETS (ici 100 Mo)
MAX_FILE_SIZE=104857600

# Dossier de téléchargement des modèles Whisper
WHISPER_MODEL_DIR=./models

# (Optionnel) Dossier d'un modèle de traduction NLLB affiné — voir training/
# TRANSLATION_MODEL_DIR=./models/nllb-fr-gcf

# Cache navigateur des fichiers statiques, en secondes
STATIC_MAX_AGE=3600
